# cp-journal - environment template. Copy to .env.local and fill in real values.
# NEVER commit .env.local. The service-role key bypasses RLS - keep it server-side only.

#  Supabase (Project Settings -> API)
# Safe to expose to the browser (public by design; protected by RLS):
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Bypasses Row Level Security. Never prefix with NEXT_PUBLIC_, never send to the client:
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

#  Operator identity (the single super-admin who runs this instance)
# Multi-tenant model: every invited user owns their own data (enforced by RLS).
# The OPERATOR is the one elevated role - they approve access requests and send
# invites (/admin/invites, POST /api/invites).
# Set this to the operator's Supabase auth user id
# (Dashboard -> Authentication -> Users -> User UID).
# Fails CLOSED: if unset, nobody is the operator (the invite surface is denied);
# regular per-user /admin journals still work.
OWNER_USER_ID=your-operator-user-uuid

#  AI provider - BRING YOUR OWN KEY (BYOK)
# AI features (code classification, revision assists, pattern normalization) run on Google Gemini.
# In production this is STRICTLY per-user: each user pastes their OWN free Gemini key in Settings,
# it is stored ENCRYPTED (see AI_KEY_ENC_SECRET below) and used only for that user's analyses. No
# shared instance key is used in production, so one user can never exhaust another's quota.
#
# REQUIRED in production: master key that encrypts every user's stored Gemini key (AES-256-GCM).
# It lives only here (never in the database), so a DB leak alone exposes nothing. Generate with:
#   openssl rand -base64 32
# WARNING: rotating/losing this value invalidates ALL stored user keys - every user must re-enter.
AI_KEY_ENC_SECRET=your-32-byte-base64-secret

# Optional Gemini model override (instance-wide default, NOT a secret; default gemini-2.5-flash-lite):
# GEMINI_MODEL=gemini-2.5-flash-lite

# DEV-ONLY convenience: when NODE_ENV != production, this key is used as a fallback so local dev /
# the live smoke test work without seeding a per-user key. It is IGNORED in production (BYOK only).
# Get a free key at aistudio.google.com -> "Get API key".
# GEMINI_API_KEY=your-gemini-api-key

#  Browser extension capture
# The extension authenticates PER USER with a revocable bearer token minted at
# /extension/connect (no shared secret). The legacy single-token /api/companion ingest
# route has been removed in favor of /api/ext/* - there is nothing to set here.

#  App URL (used by internal redirects)
# REQUIRED in production. Used for invite/auth redirect targets (NOT derived from the
# request Host header, which is client-controlled) and other internal links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

#  Email: auth & invite delivery (Supabase SMTP - no env vars)
# Login, invite, and password-reset emails are sent by Supabase via the custom SMTP
# you set in the dashboard (Authentication -> Emails -> SMTP Settings), NOT by this
# app - so there is nothing to configure here. The free, no-domain setup is Gmail SMTP:
#   Host smtp.gmail.com  Port 587  Username <your-gmail>  Password <16-char App Password>
# The Sender email MUST equal that Gmail address, and the account needs 2-Step
# Verification turned on (required to mint an App Password).

#  Email: operator notifications (SMTP, optional)
# Powers ONLY the "someone requested access" alert to the operator - completely separate
# from the auth/invite emails above. If unset, the alert is skipped silently (requests
# still appear in /admin/invites). Sent over SMTP via nodemailer.
# Reuse the SAME Gmail + App Password you put in the Supabase SMTP settings (one provider):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
# The "from" address (defaults to SMTP_USER if unset). Gmail forces this to equal SMTP_USER:
EMAIL_FROM=your-gmail@gmail.com
# Where new-access-request alerts go (the operator's inbox):
ACCESS_REQUEST_NOTIFY_EMAIL=operator@example.com
